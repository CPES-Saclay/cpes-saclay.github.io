---
import { Icon } from "astro-icon/components";

interface Props {
    href?: string;
    variant?: 'primary' | 'secondary' | 'outline';
    size?: 'default' | 'sm';
    icon?: string;
    iconPosition?: 'left' | 'right';
    position?: 'left' | 'right';
    class?: string;
    target?: string;
    rel?: string;
    triggerClass?: string;
}

const { href, variant = 'primary', size = 'default', icon, iconPosition = 'left', position = 'left', class: className, target, rel, triggerClass } = Astro.props;

const variants = {
    primary: 'bg-secondary text-primary hover:bg-primary hover:text-secondary border border-secondary',
    outline: 'bg-primary text-secondary hover:bg-secondary hover:text-primary border border-secondary'
};

const innerClass = [
    "inline-flex cursor-pointer items-center justify-center font-medium transition-all duration-200 no-underline gap-2",
    size === 'sm' ? 'px-3 py-1.5 text-sm' : 'px-5 py-4 text-base',
    variants[variant],
];
---

<div class:list={["flex mb-8", position === 'right' ? 'justify-end' : 'justify-start', className]}>
  {href && (
    <a
        href={href}
        target={target}
        rel={rel}
        class:list={[...innerClass, triggerClass]}
    >
        {icon && iconPosition === 'left' && <Icon name={icon} class="text-lg" />}
        <slot />
        {icon && iconPosition === 'right' && <Icon name={icon} class="text-lg" />}
    </a>
  )}
  {!href && (
    <button
        type="button"
        class:list={[...innerClass, triggerClass]}
    >
        {icon && iconPosition === 'left' && <Icon name={icon} class="text-lg" />}
        <slot />
        {icon && iconPosition === 'right' && <Icon name={icon} class="text-lg" />}
    </button>
  )}
</div>
