---
import { Icon } from "astro-icon/components";

interface Props {
    href: string;
    variant?: 'primary' | 'secondary' | 'outline';
    icon?: string;
    iconPosition?: 'left' | 'right';
    position?: 'left' | 'right';
    class?: string;
    target?: string;
    rel?: string;
}

const { href, variant = 'primary', icon, iconPosition = 'left', position = 'left', class: className, target, rel } = Astro.props;

const variants = {
    primary: 'bg-secondary text-primary hover:bg-primary hover:text-secondary border border-secondary',
    outline: 'bg-primary text-secondary hover:bg-secondary hover:text-primary border border-secondary'
};
---

<div class:list={["flex mb-8", position === 'right' ? 'justify-end' : 'justify-start', className]}>
  <a
      href={href}
      target={target}
      rel={rel}
      class:list={[
          "inline-flex items-center justify-center px-5 py-4 text-base font-medium transition-all duration-200 no-underline gap-2",
          variants[variant],
      ]}
  >
      {icon && iconPosition === 'left' && <Icon name={icon} class="text-lg" />}
      <slot />
      {icon && iconPosition === 'right' && <Icon name={icon} class="text-lg" />}
  </a>
</div>
