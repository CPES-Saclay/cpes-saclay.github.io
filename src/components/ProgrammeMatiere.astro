---
import { getLangFromUrl } from '../i18n/index';
import CourseDetail from './CourseDetail.astro';

import programmeFr from '../data/programme-fr.json';
import programmeEn from '../data/programme-en.json';

export interface Props {
  discipline?: string;
}

const { discipline } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const programme = lang === 'fr' ? programmeFr : programmeEn;

const CATEGORIES_ORDER = [
  'Mathématiques',
  'Informatique',
  'Économie',
  'Sciences des données',
  'Santé',
  'Société',
  'Langues',
  'Langues & Culture',
  'Ouverture',
  'Projets & Entrepreneuriat',
];

const CATEGORIES_LABELS: Record<string, { fr: string; en: string }> = {
  'Mathématiques':           { fr: 'Mathématiques',            en: 'Mathematics' },
  'Informatique':            { fr: 'Informatique',             en: 'Computer Science' },
  'Économie':                { fr: 'Économie',                 en: 'Economics' },
  'Sciences des données':    { fr: 'Sciences des données',     en: 'Data Science' },
  'Santé':                   { fr: 'Santé',                    en: 'Health' },
  'Société':                 { fr: 'Société',                  en: 'Society' },
  'Langues':                 { fr: 'Langues',                  en: 'Languages' },
  'Langues & Culture':       { fr: 'Langues & Culture',        en: 'Languages & Culture' },
  'Ouverture':               { fr: 'Ouverture',                en: 'Open Courses' },
  'Projets & Entrepreneuriat': { fr: 'Projets & Entrepreneuriat', en: 'Projects & Entrepreneurship' },
};

interface CourseWithYear {
  matiere: any;
  annee: string;
  anneeKey: string;
}

// Map English JSON category values → canonical French keys used for ordering/labels
const EN_TO_FR_CAT: Record<string, string> = {
  'Mathematics':              'Mathématiques',
  'Computer Science':         'Informatique',
  'Economics':                'Économie',
  'Data Science':             'Sciences des données',
  'Health':                   'Santé',
  'Society':                  'Société',
  'Languages':                'Langues',
  'Languages & Culture':      'Langues & Culture',
  'General Education':        'Ouverture',
  'Open Courses':             'Ouverture',
  'Projects & Entrepreneurship': 'Projets & Entrepreneuriat',
};

function normalizeCategorie(cat: string): string {
  return EN_TO_FR_CAT[cat] ?? cat;
}

const coursesByCategorie: Record<string, CourseWithYear[]> = {};

for (const [anneeKey, anneeData] of Object.entries(programme)) {
  const anneeLabel = lang === 'fr' ? `Licence ${anneeKey.slice(1)}` : `Bachelor ${anneeKey.slice(1)}`;

  for (const blocData of Object.values((anneeData as any).blocs)) {
    for (const matiere of (blocData as any).matieres) {
      const rawCat: string = matiere.categorie ?? 'Ouverture';
      const cat = normalizeCategorie(rawCat);
      if (!coursesByCategorie[cat]) coursesByCategorie[cat] = [];
      coursesByCategorie[cat].push({ matiere, annee: anneeLabel, anneeKey });
    }
  }
}

for (const courses of Object.values(coursesByCategorie)) {
  courses.sort((a, b) =>
    a.anneeKey !== b.anneeKey
      ? a.anneeKey.localeCompare(b.anneeKey)
      : b.matiere.ects - a.matiere.ects
  );
}

const allCats = CATEGORIES_ORDER.filter(c => coursesByCategorie[c]);
for (const c of Object.keys(coursesByCategorie)) {
  if (!CATEGORIES_ORDER.includes(c)) allCats.push(c);
}

const catsToShow = discipline ? allCats.filter(c => c === discipline) : allCats;
---

<section>
  {catsToShow.map(cat => {
    const courses = coursesByCategorie[cat] ?? [];
    const label = CATEGORIES_LABELS[cat]
      ? CATEGORIES_LABELS[cat][lang as 'fr' | 'en']
      : cat;
    const countLabel = lang === 'fr'
      ? `${courses.length} cours`
      : `${courses.length} course${courses.length > 1 ? 's' : ''}`;

    return (
      <div class="mb-10">
        <div class="flex flex-col-reverse md:flex-row gap-1 md:gap-3 md:items-center mb-4">
          <span class="text-secondary text-xl md:text-2xl font-semibold">{label}</span>
          <span class="bg-(--ects) px-1.5 py-1 text-[13px] text-primary leading-none w-fit">{countLabel}</span>
        </div>

        {courses.map(course => (
          <CourseDetail
            matiere={course.matiere}
            annee={course.annee}
            lang={lang}
            showAnneeBadge={true}
          />
        ))}
      </div>
    );
  })}
</section>
