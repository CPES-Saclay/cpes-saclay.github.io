---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl } from '../i18n';

interface Props {
  nom: string;
  photo?: string;
  annee: 'L1' | 'L2' | 'L3';
  parcours: 'sante' | 'societe';
  linkedin?: string | null;
  contact?: string | null;
}

const { nom, photo, annee, parcours, linkedin, contact } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const parcoursLabel = parcours === 'sante'
  ? (lang === 'fr' ? 'Santé' : 'Health')
  : (lang === 'fr' ? 'Société' : 'Society');
---

<article class="px-3 py-5 bg-secondary/5" data-annee={annee} data-parcours={parcours}>
  <div class="flex items-center gap-4">
    {photo
      ? <img loading="lazy" src={photo} alt={nom} class="w-16 h-16 rounded-full mb-0 object-cover shrink-0 etudiant-photo" />
      : <div class="w-16 h-16 rounded-full shrink-0 flex items-center justify-center font-bold text-xl bg-secondary text-primary">{nom[0]}</div>
    }
    <div class="flex-1 min-w-0 flex flex-col gap-0">
      <div class="flex items-center justify-between gap-2">
        <span class="font-semibold text-[0.95rem] leading-tight text-secondary m-0">{nom}</span>
        {(linkedin || contact) && (
          <div class="flex gap-1">
            {linkedin && (
              <a href={linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center text-[1.1rem] no-underline text-secondary bg-transparent border-none" aria-label="LinkedIn">
                <Icon name="ri:linkedin-box-fill" />
              </a>
            )}
            {contact && (
              <a href={`mailto:${contact}`} class="inline-flex items-center justify-center text-[1.1rem] no-underline text-secondary bg-transparent border-none" aria-label={`Contacter ${nom}`}>
                <Icon name="ri:mail-fill" />
              </a>
            )}
          </div>
        )}
      </div>
      <div class="flex gap-[0.3rem] pt-2 flex-wrap">
        <span class="text-sm font-semibold h-6 w-7 text-center uppercase border border-secondary text-primary bg-secondary">{annee}</span>
        <span class="text-sm font-medium h-6 px-1.5 border border-secondary text-secondary">{parcoursLabel}</span>
      </div>
    </div>
  </div>
</article>


<style>
  .etudiant-photo {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
</style>