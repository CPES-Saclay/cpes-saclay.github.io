---
interface Props {
  auteur: string;
  annee: 'L1' | 'L2' | 'L3';
  parcours: 'sante' | 'societe';
  photo?: string;
}

const { auteur, annee, parcours, photo } = Astro.props;

const parcoursLabel = parcours === 'sante' ? 'Santé' : 'Société';
---

<figure class="flex flex-col gap-6 p-8 bg-base-200 m-0">
  <blockquote class="citation text-base leading-[1.7] text-secondary m-0 italic">
    <slot />
  </blockquote>
  <figcaption class="flex items-center gap-[0.875rem]">
    {photo
      ? <img loading="lazy" src={photo} alt={auteur} class="w-11 h-11 rounded-full object-cover shrink-0" />
      : <div class="w-11 h-11 rounded-full shrink-0 flex items-center justify-center font-bold text-base bg-secondary text-primary">{auteur[0]}</div>
    }
    <div class="flex flex-col gap-[0.3rem]">
      <span class="font-semibold text-[0.9rem] text-secondary">{auteur}</span>
      <div class="flex gap-[0.3rem]">
        <span class="text-sm font-semibold h-6 w-7 flex items-center justify-center uppercase border border-secondary text-primary bg-secondary">{annee}</span>
        <span class="text-sm font-medium h-6 px-1.5 flex items-center border border-secondary text-secondary">{parcoursLabel}</span>
      </div>
    </div>
  </figcaption>
</figure>

<style>
  .citation::before { content: «\00a0; }
  .citation::after  { content: \00a0»; }
</style>
